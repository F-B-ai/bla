rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Academy content: staff can upload, authenticated users can read
    match /academy/{courseId}/{folder}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Postural images
    match /postural/{studentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // BIA documents
    match /bia/{studentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Nutrition team attachments
    match /nutritionTeam/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
